# --- Google Drive API Configuration ---
# 1. Go to https://console.cloud.google.com/
# 2. Enable "Google Drive API"
# 3. Create "OAuth 2.0 Client ID" (Web Application)
# 4. Add your production URL to "Authorized JavaScript origins"
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# --- Microsoft OneDrive API Configuration ---
# 1. Go to https://portal.azure.com/ (App registrations)
# 2. Create a new registration (Multitenant + Personal)
# 3. Add your production URL as a "Single-page application (SPA)" Redirect URI
VITE_ONEDRIVE_CLIENT_ID=your_onedrive_client_id_here

# --- Google Gemini API (Optional for AI Advisor) ---
# Note: AI Studio handles this automatically in the preview, 
# but you may need it for external hosting.
VITE_GEMINI_API_KEY=your_gemini_api_key_here
